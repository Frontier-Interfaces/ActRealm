  2804	fn spawn_oauth_quota_refresh(
  2805	    quota_state: Arc<Mutex<QuotaState>>,
  2806	    store: RuntimeStore,
  2807	    paths: QuotaPaths,
  2808	) {
  2809	    let state_on_failure = quota_state.clone();
  2810	    let result = thread::Builder::new()
  2811	        .name("actrealm-claude-quota".to_owned())
  2812	        .spawn(move || {
  2813	            let now = now_millis();
  2814	            let mut collector = QuotaCollector::new(paths);
  2815	            let result = collector.refresh_claude_oauth(now).map(|mut entries| {
  2816	                entries.extend(collector.collect_codex(now));
  2817	                entries
  2818	            });
  2819	            let Ok(mut quota) = quota_state.lock() else {
  2820	                return;
  2821	            };
  2822	            quota.oauth_refresh_in_progress = false;
  2823	            let Ok(entries) = result else { return };
  2824	            quota.entries = entries.clone();
  2825	            quota.refreshed_at = Some(Instant::now());
  2826	            quota.claude_cache_modified_at = fs::metadata(quota.collector.paths().claude_cache())
  2827	                .and_then(|metadata| metadata.modified())
  2828	                .ok();
  2829	            drop(quota);
  2830	            let persisted = entries.iter().filter_map(quota_record).collect::<Vec<_>>();
  2831	            let _ = store.replace_quota_snapshots(persisted);
  2832	        });
  2833	    if result.is_err() {
  2834	        if let Ok(mut quota) = state_on_failure.lock() {
  2835	            quota.oauth_refresh_in_progress = false;
  2836	        }
  2837	    }
  2838	}
