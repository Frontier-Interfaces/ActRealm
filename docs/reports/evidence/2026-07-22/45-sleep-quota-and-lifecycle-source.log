  2796	    let paths = start_oauth_refresh.then(|| quota.collector.paths().clone());
  2797	    drop(quota);
  2798	    if let Some(paths) = paths {
  2799	        spawn_oauth_quota_refresh(state.quota.clone(), state.store.clone(), paths);
  2800	    }
