  2572	async fn websocket_loop(mut socket: WebSocket, state: AppState) {
  2573	    let _connection = WebSocketConnectionGuard::new(state.websocket_connections.clone());
  2574	    let mut last_payload = String::new();
  2575	    let mut last_heartbeat = Instant::now();
  2576	    while !state.shutdown_flag.load(Ordering::Acquire) {
  2577	        let Ok(snapshot) = snapshot_value(&state) else {
  2578	            break;
  2579	        };
  2580	        let payload = json!({ "type": "snapshot", "snapshot": snapshot }).to_string();
  2581	        if payload != last_payload {
  2582	            if socket
  2583	                .send(Message::Text(payload.clone().into()))
  2584	                .await
  2585	                .is_err()
  2586	            {
  2587	                break;
  2588	            }
  2589	            last_payload = payload;
  2590	        }
  2591	        if last_heartbeat.elapsed() >= state.heartbeat_interval {
  2592	            let heartbeat = json!({
  2593	                "type": "heartbeat",
  2594	                "serverTime": now_millis(),
  2595	            })
  2596	            .to_string();
  2597	            if socket.send(Message::Text(heartbeat.into())).await.is_err() {
  2598	                break;
  2599	            }
  2600	            last_heartbeat = Instant::now();
  2601	        }
  2602	        match tokio::time::timeout(state.snapshot_interval, socket.recv()).await {
  2603	            Ok(Some(Ok(Message::Close(_)))) | Ok(None) | Ok(Some(Err(_))) => break,
  2604	            Ok(Some(Ok(_))) | Err(_) => {}
  2605	        }
  2606	    }
  2607	}
