  2785	        quota.oauth_refresh_in_progress = true;
  2786	    }
  2787	    if refresh {
  2788	        let now = now_millis();
  2789	        quota.entries = quota.collector.collect(now);
  2790	        quota.refreshed_at = Some(Instant::now());
  2791	        quota.claude_cache_modified_at = claude_cache_modified_at;
  2792	        let persisted = quota.entries.iter().filter_map(quota_record).collect();
  2793	        state.store.replace_quota_snapshots(persisted)?;
  2794	    }
