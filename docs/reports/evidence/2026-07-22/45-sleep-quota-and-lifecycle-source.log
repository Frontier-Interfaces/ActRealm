   333	    private func streamLoop() async {
   334	        var attempt = 0
   335	        while !Task.isCancelled {
   336	            guard let baseURL, let cookie = sessionCookie, let csrfToken else { return }
   337	            guard var components = URLComponents(
   338	                url: baseURL.appendingPathComponent("api/v1/ws"),
   339	                resolvingAgainstBaseURL: false
   340	            ) else { return }
   341	            components.scheme = baseURL.scheme == "https" ? "wss" : "ws"
   342	            components.queryItems = [URLQueryItem(name: "csrf", value: csrfToken)]
   343	            guard let wsURL = components.url else { return }
   344
   345	            var request = URLRequest(url: wsURL)
   346	            request.setValue("actrealm_session=\(cookie)", forHTTPHeaderField: "Cookie")
   347	            request.setValue(originValue(for: baseURL), forHTTPHeaderField: "Origin")
   348	            let task = session.webSocketTask(with: request)
   349	            webSocketTask = task
   350	            task.resume()
   351	            connectionState = .live
   352	            attempt = 0
   353
   354	            do {
   355	                while !Task.isCancelled {
   356	                    let message = try await task.receive()
   357	                    switch message {
   358	                    case .string(let text): handleSocketText(text)
   359	                    case .data(let data):
   360	                        if let text = String(data: data, encoding: .utf8) { handleSocketText(text) }
   361	                    @unknown default: break
   362	                    }
   363	                }
   364	            } catch {
   365	                // Reconnect below. The last truthful snapshot stays visible.
   366	            }
   367	            if Task.isCancelled { return }
   368
   369	            connectionState = .connecting
   370	            attempt += 1
   371	            let delaySeconds = min(pow(2.0, Double(attempt)), 30)
   372	            try? await Task.sleep(for: .seconds(delaySeconds))
   373	        }
   374	    }
